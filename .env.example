# ─────────────────────────────────────────────────────────────────────────
# YÉKI backend — variables d'environnement
# Copier ce fichier vers ".env" (même dossier, à côté de manage.py) et
# renseigner les vraies valeurs. Ne JAMAIS commiter le fichier ".env".
# ─────────────────────────────────────────────────────────────────────────

# Clé secrète Django (signature des sessions, tokens CSRF, etc.).
# Générer une nouvelle valeur avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Compte Gmail utilisé comme expéditeur SMTP (EMAIL_HOST_USER / DEFAULT_FROM_EMAIL).
EMAIL_HOST_USER=

# Mot de passe d'application Gmail (PAS le mot de passe du compte) généré sur
# https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=

# Clé API du compte marchand CinetPay (tableau de bord CinetPay > Intégration).
CINETPAY_API_KEY=

# Identifiant de site marchand CinetPay (tableau de bord CinetPay > Intégration).
CINETPAY_SITE_ID=

# ── Base de données PostgreSQL (production uniquement, config/settings/production.py) ──
# Sans effet en développement local (SQLite, voir config/settings/development.py).
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
